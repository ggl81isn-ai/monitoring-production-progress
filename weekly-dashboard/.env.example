# --- Notion（npm run notion:payload）---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# タグ列（multi_select または select の表示名）。未指定時は「タグ」列を想定
NOTION_TAG_PROPERTY=タグ
# 既定: value = 「タグ」で NOTION_TAG_VALUE（制作）が付いている行だけ（完了率もこの集合のみ）
# non_empty = タグが1つ以上 / both = 空でない かつ NOTION_TAG_VALUE
NOTION_TAG_FILTER_MODE=value
NOTION_TAG_VALUE=制作
# 切り分け: true のとき notion:payload で診断 JSON を data/notion-diagnostic.json に書き、コンソールにも出す
# NOTION_DIAGNOSTIC=true
# 診断ファイルの保存先を変える（weekly-dashboard からの相対パスまたは絶対パス）
# NOTION_DIAGNOSTIC_FILE=data/notion-diagnostic.json
# 1 / true のときだけタグ条件なしで DB 全件（非推奨: 件数が多いと重い）
# NOTION_SKIP_TAG_FILTER=true

# 完了判定: 列の表示名（DB と一致）。型は status / select / multi_select（複数タグのどれかが完了名に一致すれば完了）
# 表示名が合わないと完了 0 件扱いになりやすい。列名が違うときはここを実際の名前に変更する
NOTION_STATUS_PROPERTY=ステータス
NOTION_DONE_STATUS_VALUES=完了,Done,done
# レポートで「進行中」として数えるステータス（既定: 進行中）。完了セットと重複するとエラー
NOTION_IN_PROGRESS_STATUS_VALUES=進行中
# NOTION_STATUS_DISABLE=true

# マイルストーン: number 1〜4 または select（その場合は順序必須）
NOTION_MILESTONE_PROPERTY=マイルストーン
# select のとき、左から 1〜4 に対応するオプション名
# NOTION_MILESTONE_SELECT_ORDER=要件,コア,検証,運用
# NOTION_MILESTONE_DISABLE=true

NOTION_PRIORITY_PROPERTY=
# 改行区切りで今週の目標を固定したいとき（無ければ未完了タスク名から最大3件）
# NOTION_WEEK_GOALS=行1\n行2
# 改行区切りで次週アクションを固定したいとき（無ければ未完了タスク名から最大3件）
# NOTION_NEXT_ACTIONS=行1\n行2
# false のとき、NOTION_WEEK_GOALS 未設定でもタスクから目標を自動生成しない
# NOTION_DERIVE_GOALS_FROM_TASKS=true
# false のとき、NOTION_NEXT_ACTIONS 未設定でもタスクから次週アクションを自動生成しない
# NOTION_DERIVE_NEXT_ACTIONS_FROM_TASKS=true

NOTION_WEEK_LABEL=
NOTION_REPORT_LABEL=週次レポート・自分用 / アプリ制作
NOTION_REPORT_TITLE=アプリ制作 — 進捗状況（Notion連携）
NOTION_PROJECT_ID=app-production
NOTION_TEMPLATE_VERSION=11
# NOTION_MILESTONE_LABELS_JSON=["要件・方針FIX","コア実装","検証・公開準備","運用・改善"]
# NOTION_PROGRESS_MEMO_PROPERTY=進捗メモ

# --- LINE（npm run push:line / 手順は docs/line-setup-ja.md）---
# トークンとユーザー ID の両方があるときだけ送信。どちらか無いとスキップ（エラーにしない）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_TO_USER_ID=（U 始まり。LINE Developers → チャネル「基本設定」の Your user ID が手軽。出ないときは docs/line-setup-ja.md の方法 0）
# 画像付き: (A) 両方セットで手動 URL (B) DISCORD_WEBHOOK_URL → dist/report.png を Discord に投稿し URL 取得（推奨）(C) IMGUR_CLIENT_ID → Imgur（新規 Client ID が取れないことが多い）
# LINE_IMAGE_ORIGINAL_URL=
# LINE_IMAGE_PREVIEW_URL=
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...
# IMGUR_CLIENT_ID=
# 既定 dist/report.png。変えたいときだけ（weekly-dashboard からの相対 or 絶対）
# LINE_REPORT_PNG_PATH=dist/report.png
# 一括: Notion→生成→スクショ→LINE は npm run build:weekly:line
# Notion なしで試す: npm run build:weekly:sample:line
