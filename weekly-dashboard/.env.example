# --- Notion（npm run notion:payload）---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# タグ列（multi_select または select の表示名）。未指定時は「タグ」列を想定
NOTION_TAG_PROPERTY=タグ
# 既定: value = 「タグ」で NOTION_TAG_VALUE（制作）が付いている行だけ（完了率もこの集合のみ）
# non_empty = タグが1つ以上 / both = 空でない かつ NOTION_TAG_VALUE
NOTION_TAG_FILTER_MODE=value
NOTION_TAG_VALUE=制作
# 1 / true のときだけタグ条件なしで DB 全件（非推奨: 件数が多いと重い）
# NOTION_SKIP_TAG_FILTER=true

# 完了判定（status または select の表示名をカンマ区切り）
NOTION_STATUS_PROPERTY=ステータス
NOTION_DONE_STATUS_VALUES=完了,Done,done
# NOTION_STATUS_DISABLE=true

# マイルストーン: number 1〜4 または select（その場合は順序必須）
NOTION_MILESTONE_PROPERTY=マイルストーン
# select のとき、左から 1〜4 に対応するオプション名
# NOTION_MILESTONE_SELECT_ORDER=要件,コア,検証,運用
# NOTION_MILESTONE_DISABLE=true

NOTION_PRIORITY_PROPERTY=
# 改行区切りで今週の目標を固定したいとき（無ければ未完了タスク名から最大3件）
# NOTION_WEEK_GOALS=行1\n行2

NOTION_WEEK_LABEL=
NOTION_REPORT_LABEL=週次レポート・自分用 / アプリ制作
NOTION_REPORT_TITLE=アプリ制作 — 進捗状況（Notion連携）
NOTION_PROJECT_ID=app-production
NOTION_TEMPLATE_VERSION=11
# NOTION_MILESTONE_LABELS_JSON=["要件・方針FIX","コア実装","検証・公開準備","運用・改善"]
# NOTION_PROGRESS_MEMO_PROPERTY=進捗メモ

# --- LINE（npm run push:line）---
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_TO_USER_ID=
# 画像付きにする場合のみ（HTTPS。LINE のサーバから取得可能な URL）
# LINE_IMAGE_ORIGINAL_URL=
# LINE_IMAGE_PREVIEW_URL=
